{
  "schema": "carbon-scheduler.semantic-trace.v0",
  "name": "blocking_send",
  "source": {
    "repo": "/data/repos/fenris/carbonengine/scheduler",
    "tests": [
      "tests/python/scheduler/tests/test_channel.py::TestChannels::test_blocking_send"
    ]
  },
  "scenario": {
    "channels": [
      {
        "id": "ch0",
        "preference": -1
      }
    ],
    "tasklets": [
      {
        "id": "sender",
        "body": [
          {
            "op": "send",
            "channel": "ch0",
            "value": 1
          }
        ]
      }
    ],
    "entrypoint": {
      "op": "run_tasklet",
      "tasklet": "sender"
    }
  },
  "events": [
    {
      "seq": 0,
      "kind": "scheduler.start",
      "actor": "main",
      "current": "main",
      "run_count": 1,
      "runnable": [
        "main"
      ]
    },
    {
      "seq": 1,
      "kind": "channel.new",
      "actor": "main",
      "channel": "ch0",
      "preference": -1,
      "balance": 0
    },
    {
      "seq": 2,
      "kind": "tasklet.new",
      "actor": "main",
      "tasklet": "sender",
      "alive": true,
      "scheduled": true,
      "run_count": 2,
      "runnable": [
        "main",
        "sender"
      ]
    },
    {
      "seq": 3,
      "kind": "scheduler.switch",
      "actor": "main",
      "from": "main",
      "to": "sender",
      "reason": "run_tasklet"
    },
    {
      "seq": 4,
      "kind": "channel.send.attempt",
      "actor": "sender",
      "channel": "ch0",
      "value": 1,
      "waiting_receivers": []
    },
    {
      "seq": 5,
      "kind": "channel.block",
      "actor": "sender",
      "channel": "ch0",
      "direction": "send",
      "balance": 1,
      "blocked_senders": [
        "sender"
      ],
      "blocked_receivers": []
    },
    {
      "seq": 6,
      "kind": "scheduler.switch",
      "actor": "sender",
      "from": "sender",
      "to": "main",
      "reason": "blocked"
    }
  ],
  "expect": {
    "current": "main",
    "run_count": 1,
    "tasklets": {
      "sender": {
        "alive": true,
        "blocked": true,
        "blocked_on": "ch0",
        "blocked_direction": "send",
        "scheduled": false
      }
    },
    "channels": {
      "ch0": {
        "balance": 1,
        "blocked_senders": [
          "sender"
        ],
        "blocked_receivers": []
      }
    }
  }
}

