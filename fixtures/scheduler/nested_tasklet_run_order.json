    {"seq":3,"kind":"tasklet.new","actor":"main","tasklet":"t5","alive":true,"scheduled":true,"run_count":4,"runnable":["main","t1","nested","t5"]},
    {"seq":4,"kind":"scheduler.run.start","actor":"main","limit":"until_idle"},
    {"seq":5,"kind":"scheduler.switch","actor":"main","from":"main","to":"t1","reason":"next_runnable"},
    {"seq":6,"kind":"tasklet.observed","actor":"t1","target":"completed","value":"t1","completed":["t1"]},
    {"seq":7,"kind":"tasklet.complete","actor":"t1","tasklet":"t1","alive":false},
    {"seq":8,"kind":"scheduler.switch","actor":"t1","from":"t1","to":"main","reason":"tasklet_complete"},
    {"seq":9,"kind":"scheduler.switch","actor":"main","from":"main","to":"nested","reason":"next_runnable"},
    {"seq":10,"kind":"tasklet.new","actor":"nested","tasklet":"t2","alive":true,"scheduled":true,"run_count":3,"runnable":["main","t2","t5"]},
    {"seq":11,"kind":"tasklet.new","actor":"nested","tasklet":"t3","alive":true,"scheduled":true,"run_count":4,"runnable":["main","t2","t3","t5"]},
    {"seq":12,"kind":"tasklet.new","actor":"nested","tasklet":"t4","alive":true,"scheduled":true,"run_count":5,"runnable":["main","t2","t3","t4","t5"]},
    {"seq":13,"kind":"scheduler.switch","actor":"nested","from":"nested","to":"t2","reason":"run_tasklet"},
    {"seq":14,"kind":"tasklet.observed","actor":"t2","target":"completed","value":"t2","completed":["t1","t2"]},
    {"seq":15,"kind":"tasklet.complete","actor":"t2","tasklet":"t2","alive":false},
    {"seq":16,"kind":"scheduler.switch","actor":"t2","from":"t2","to":"main","reason":"tasklet_complete"},
    {"seq":17,"kind":"scheduler.switch","actor":"main","from":"main","to":"t3","reason":"nested_next_runnable"},
    {"seq":18,"kind":"tasklet.observed","actor":"t3","target":"completed","value":"t3","completed":["t1","t2","t3"]},
    {"seq":19,"kind":"tasklet.complete","actor":"t3","tasklet":"t3","alive":false},
    {"seq":20,"kind":"scheduler.switch","actor":"t3","from":"t3","to":"main","reason":"tasklet_complete"},
    {"seq":21,"kind":"scheduler.switch","actor":"main","from":"main","to":"t4","reason":"nested_next_runnable"},
    {"seq":22,"kind":"tasklet.observed","actor":"t4","target":"completed","value":"t4","completed":["t1","t2","t3","t4"]},
    {"seq":23,"kind":"tasklet.complete","actor":"t4","tasklet":"t4","alive":false},
    {"seq":24,"kind":"scheduler.switch","actor":"t4","from":"t4","to":"main","reason":"run_complete"},
