{
  "schema": "carbon-scheduler.semantic-trace.v0",
  "name": "fixture_teardown_unblock_all_channels",
  "source": {
    "repo": "carbonengine/scheduler",
    "tests": [
      "tests/python/scheduler/tests/test_utils.py::SchedulerTestCaseBase.tearDown",
      "carbonengine/scheduler/src/Channel.cpp::UnblockAllActiveChannels"
    ],
    "legacy_behavior": [
      "Scheduler teardown calls unblock_all_channels rather than clearing known channels one by one.",
      "Only active channels with nonzero balance are cleared and counted."
    ]
  },
  "check_events": false,
  "scenario": {
    "channels": [
      {
        "id": "send_queue"
      },
      {
        "id": "receive_queue"
      },
      {
        "id": "idle_queue"
      }
    ],
    "tasklets": [
      {
        "id": "blocked_sender",
        "body": [
          {
            "op": "send",
            "channel": "send_queue",
            "value": "payload"
          }
        ]
      },
      {
        "id": "blocked_receiver",
        "body": [
          {
            "op": "receive",
            "channel": "receive_queue"
          }
        ]
      }
    ],
    "entrypoint": {
      "op": "script",
      "steps": [
        {
          "op": "run_scheduler"
        }
      ]
    }
  },
  "expect": {
    "current": "main",
    "run_count": 1,
    "blocked_tasklet_count": 2,
    "blocked_channel_count": 2,
    "active_channel_count": 3,
    "active_tasklet_count": 3,
    "channels": {
      "send_queue": {
        "balance": 1,
        "blocked_senders": [
          "blocked_sender"
        ],
        "blocked_receivers": []
      },
      "receive_queue": {
        "balance": -1,
        "blocked_senders": [],
        "blocked_receivers": [
          "blocked_receiver"
        ]
      },
      "idle_queue": {
        "balance": 0,
        "blocked_senders": [],
        "blocked_receivers": []
      }
    }
  },
  "teardown": {
    "steps": [
      {
        "op": "unblock_all_channels"
      },
      {
        "op": "run_scheduler"
      }
    ],
    "expect": {
      "current": "main",
      "run_count": 1,
      "blocked_tasklet_count": 0,
      "blocked_channel_count": 0,
      "active_channel_count": 3,
      "active_tasklet_count": 1,
      "all_time_tasklet_count": 3,
      "tasklets": {
        "blocked_sender": {
          "alive": false,
          "blocked": false,
          "scheduled": false,
          "pending_exit": false
        },
        "blocked_receiver": {
          "alive": false,
          "blocked": false,
          "scheduled": false,
          "pending_exit": false
        }
      },
      "channels": {
        "send_queue": {
          "balance": 0,
          "blocked_senders": [],
          "blocked_receivers": []
        },
        "receive_queue": {
          "balance": 0,
          "blocked_senders": [],
          "blocked_receivers": []
        },
        "idle_queue": {
          "balance": 0,
          "blocked_senders": [],
          "blocked_receivers": []
        }
      }
    }
  },
  "trace_expect": {
    "contains_in_order": [
      {
        "kind": "scheduler.unblock_all_channels",
        "actor": "main",
        "channels": [
          "receive_queue",
          "send_queue"
        ],
        "unblocked_channel_count": 2,
        "active_channel_count": 3,
        "blocked_channel_count": 0
      }
    ],
    "match_counts": [
      {
        "event": {
          "kind": "scheduler.unblock_all_channels"
        },
        "count": 1
      },
      {
        "event": {
          "kind": "channel.clear"
        },
        "count": 2
      }
    ]
  }
}
