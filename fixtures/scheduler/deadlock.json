    },
    {
      "seq": 1,
      "kind": "channel.new",
      "actor": "main",
      "channel": "ch0",
      "preference": -1,
      "balance": 0
    },
    {
      "seq": 2,
      "kind": "tasklet.batch_new",
      "actor": "main",
      "tasklets": [
        "noop_0",
        "noop_1",
        "noop_2",
        "noop_3",
        "noop_4",
        "noop_5",
        "noop_6",
        "noop_7",
        "noop_8",
        "noop_9"
      ],
      "run_count": 11
    },
    {
      "seq": 3,
      "kind": "channel.receive.attempt",
      "actor": "main",
      "channel": "ch0",
      "waiting_senders": []
    },
    {
      "seq": 4,
      "kind": "scheduler.drain_before_block",
      "actor": "main",
      "reason": "main_receive_would_block",
      "tasklets": [
