{
  "schema": "carbon-scheduler.semantic-trace.v0",
  "name": "run_order",
  "source": {
    "repo": "carbonengine/scheduler",
    "tests": [
      "tests/python/scheduler/tests/test_scheduler.py::TestScheduleOrderBase::test_scheduler_run_order"
