          "op": "run_scheduler"
        },
        {
          "op": "close",
          "channel": "ch0"
        },
        {
          "op": "receive",
          "channel": "ch0",
          "bind": "main_received"
        },
        {
          "op": "open",
          "channel": "ch0"
        },
        {
          "op": "insert",
          "tasklet": "receiver_after_open"
        },
        {
          "op": "run_scheduler"
        },
        {
          "op": "send",
          "channel": "ch0",
          "value": "after-open"
        },
        {
          "op": "run_scheduler"
        }
      ]
