            "op": "send",
            "channel": "ch0",
            "value": "before-close"
          }
        ]
      },
      {
        "id": "receiver_after_open",
        "initially_scheduled": false,
        "body": [
          {
            "op": "receive",
            "channel": "ch0",
            "bind": "received"
          },
          {
            "op": "append",
            "target": "completed",
            "value": "receiver_after_open"
          }
        ]
      }
    ],
    "entrypoint": {
      "op": "script",
