{
  "schema": "carbon-scheduler.semantic-trace.v0",
  "name": "channel_close_open_parity",
  "source": {
    "repo": "carbonengine/scheduler",
    "tests": [
      "tests/python/scheduler/tests/test_channel.py::TestChannels::test_closing",
      "tests/python/scheduler/tests/test_channel.py::TestChannels::test_open",
      "carbonengine/scheduler/src/Channel.cpp::Close",
      "carbonengine/scheduler/src/Channel.cpp::Open",
      "carbonengine/scheduler/src/Channel.cpp::UpdateCloseState"
    ]
  },
  "check_events": true,
  "scenario": {
    "channels": [
