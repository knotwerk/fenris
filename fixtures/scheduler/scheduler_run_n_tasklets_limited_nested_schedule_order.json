{
  "schema": "carbon-scheduler.semantic-trace.v0",
  "name": "scheduler_run_n_tasklets_limited_nested_schedule_order",
  "source": {
    "repo": "/data/repos/fenris/carbonengine/scheduler",
    "tests": [
      "tests/python/scheduler/tests/test_utils.py::TestWithLimit",
      "tests/python/scheduler/tests/test_scheduler.py::TestScheduleOrderWithLimitWithNestedTasklets::test_nested_tasklet_run_order_with_schedule"
    ],
    "legacy_behavior": [
      "The limited scheduler harness repeatedly calls run_n_tasklets(1) while runnable tasklets remain.",
      "Nested tasklets enabled should preserve the legacy completion order t1, t2, t3, t4 across one-tasklet pumps."
    ]
  },
  "check_events": false,
  "scenario": {
    "nested_tasklets": true,
    "tasklets": [
      { "id": "t1", "body": [{ "op": "append", "target": "completed", "value": "t1" }] },
      {
        "id": "nested",
        "body": [
          { "op": "spawn", "tasklet": "t2" },
          { "op": "spawn", "tasklet": "yield" },
          { "op": "spawn", "tasklet": "t3" },
          { "op": "run_tasklet", "tasklet": "t2" }
        ]
      },
      { "id": "t4", "body": [{ "op": "append", "target": "completed", "value": "t4" }] },
      {
        "id": "t2",
        "initially_scheduled": false,
        "body": [{ "op": "append", "target": "completed", "value": "t2" }]
      },
      {
        "id": "yield",
        "initially_scheduled": false,
        "body": [{ "op": "schedule" }]
      },
      {
        "id": "t3",
        "initially_scheduled": false,
        "body": [{ "op": "append", "target": "completed", "value": "t3" }]
      }
    ],
    "entrypoint": {
      "op": "script",
      "steps": [
        { "op": "run_scheduler_n", "count": 1 },
        { "op": "run_scheduler_n", "count": 1 },
        { "op": "run_scheduler_n", "count": 1 },
        { "op": "run_scheduler_n", "count": 1 },
        { "op": "run_scheduler_n", "count": 1 }
      ]
    }
  },
  "trace_expect": {
    "contains_in_order": [
      { "kind": "scheduler.run.start", "limit": 1 },
      { "kind": "tasklet.observed", "actor": "t1", "value": "t1" },
      { "kind": "scheduler.run.start", "limit": 1 },
      { "kind": "tasklet.observed", "actor": "t2", "value": "t2" },
      {
        "kind": "scheduler.schedule",
        "actor": "yield",
        "position": "back",
        "runnable": ["main", "t3", "t4", "yield"]
      },
      { "kind": "tasklet.observed", "actor": "t3", "value": "t3" },
      { "kind": "scheduler.run.start", "limit": 1 },
      { "kind": "tasklet.observed", "actor": "t4", "value": "t4" },
      { "kind": "scheduler.run.start", "limit": 1 },
      { "kind": "tasklet.complete", "tasklet": "yield" }
    ],
    "match_counts": [
      { "event": { "kind": "scheduler.run.start" }, "count": 5 },
      { "event": { "kind": "scheduler.run.start", "limit": 1 }, "count": 5 },
      { "event": { "kind": "scheduler.schedule", "position": "back" }, "count": 1 }
    ]
  },
  "expect": {
    "current": "main",
    "run_count": 1,
    "active_tasklet_count": 1,
    "all_time_tasklet_count": 7,
    "completed": ["t1", "t2", "t3", "t4"]
  }
}
