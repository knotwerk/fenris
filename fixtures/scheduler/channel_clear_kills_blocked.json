      "runnable": [
        "main",
        "sender1",
        "sender2"
      ],
      "scheduled": true,
      "seq": 3,
      "tasklet": "sender2"
    },
    {
      "actor": "main",
      "kind": "scheduler.run.start",
      "limit": "until_idle",
      "seq": 4
    },
    {
      "actor": "main",
      "from": "main",
