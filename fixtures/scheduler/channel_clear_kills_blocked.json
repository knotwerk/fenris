      },
      {
        "id": "sender2",
        "body": [
          {
            "op": "send",
            "channel": "ch0",
            "value": "sender2"
          }
        ]
      }
    ],
    "entrypoint": {
      "op": "script",
      "steps": [
        {
          "op": "run_scheduler"
        },
        {
          "op": "clear",
          "channel": "ch0"
        }
      ]
    }
  },
  "events": [
    {
      "actor": "main",
