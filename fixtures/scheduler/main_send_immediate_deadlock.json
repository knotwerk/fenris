{
  "schema": "carbon-scheduler.semantic-trace.v0",
  "name": "main_send_immediate_deadlock",
  "source": {
    "repo": "carbonengine/scheduler",
    "tests": [
      "tests/python/scheduler/tests/test_channel.py::TestChannels::test_main_tasklet_blocking_without_receiver",
      "carbonengine/scheduler/src/Channel.cpp::Send"
    ]
  },
  "check_events": true,
  "scenario": {
    "channels": [
      {
        "id": "ch0",
        "preference": -1
      }
    ],
    "tasklets": [],
    "entrypoint": {
      "op": "script",
      "steps": [
        {
          "op": "send",
          "channel": "ch0",
          "value": 1
        }
      ]
    }
  },
  "events": [
    {
      "actor": "main",
      "current": "main",
      "kind": "scheduler.start",
      "run_count": 1,
      "runnable": [
        "main"
      ],
      "seq": 0
    },
    {
      "actor": "main",
      "balance": 0,
      "channel": "ch0",
      "kind": "channel.new",
      "preference": -1,
      "seq": 1
    },
    {
      "actor": "main",
      "channel": "ch0",
      "kind": "channel.send.attempt",
      "payload_kind": "value",
      "seq": 2,
      "value": 1,
      "waiting_receivers": []
    },
    {
      "actor": "main",
      "balance": 0,
      "channel": "ch0",
      "error": {
        "message_contains": "Deadlock",
        "type": "RuntimeError"
      },
      "kind": "scheduler.deadlock",
      "main_blocked": false,
      "operation": "send",
      "seq": 3
    }
  ],
  "expect": {
    "current": "main",
    "run_count": 1,
    "error": {
      "type": "RuntimeError",
      "message_contains": "Deadlock"
    },
    "channels": {
      "ch0": {
        "balance": 0,
        "blocked_senders": [],
        "blocked_receivers": []
      }
    }
  }
}
